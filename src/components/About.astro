---
import { t, type Locale } from '../i18n/utils';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const s = t(locale).about;
---
<section id="about">
  <div class="container">
    <h2>{s.heading}</h2>
    <p>{s.body}</p>
  </div>
</section>

<style>
  p { max-width: 42rem; color: var(--text-primary); }
</style>
